# ---------------------------------------------------------------------------
# DataFolio backend configuration
#
# Copy to `.env.local` and fill in to run against real GitHub repos. Leave unset
# to run in mock mode (in-memory sample data, no GitHub, no auth).
# See docs/github-app.md for how to register the GitHub App.
# ---------------------------------------------------------------------------

# Turn on the GitHub-backed data layer + real sign-in. Anything other than
# "github" (or unset) keeps the app in mock mode.
NEXT_PUBLIC_DATAFOLIO_BACKEND=github

# --- GitHub App credentials (from the App's settings page) ---
GITHUB_APP_ID=123456
GITHUB_APP_CLIENT_ID=Iv1.0123456789abcdef
GITHUB_APP_CLIENT_SECRET=your-app-client-secret

# The App private key (.pem). Either paste the PEM with real newlines inside
# quotes, or base64-encode the whole file and paste one line:
#   base64 -i your-app.private-key.pem | tr -d '\n'
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# --- Session ---
# Encrypts the session cookie. Must be at least 32 characters. Generate one:
#   openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# --- App ---
# The repo name every learner creates from the template repository.
DATAFOLIO_REPO_NAME=portfolio-evidence
# Absolute base URL of this app (used for the OAuth redirect_uri).
APP_BASE_URL=http://localhost:3000
