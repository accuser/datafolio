{
  "name": "datafolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "standards:build": "tsx scripts/build-standards.ts",
    "standards:check": "tsx scripts/build-standards.ts --check",
    "test": "npm run standards:check && npm run test:contrast && npm run test:standards && npm run test:domain && npm run test:cards && npm run test:anki && npm run test:cards-md && npm run test:roundtrip && npm run test:commit && npm run test:store && npm run test:card-store && npm run test:validation && npm run test:portfolios",
    "test:contrast": "tsx lib/contrast.test.ts",
    "test:standards": "tsx lib/standards/standards.test.ts",
    "test:domain": "tsx lib/domain.test.ts",
    "test:cards": "tsx lib/cards.test.ts",
    "test:anki": "tsx lib/anki.test.ts",
    "test:cards-md": "tsx lib/github/cards-md.roundtrip.ts",
    "test:roundtrip": "tsx lib/github/frontmatter.roundtrip.ts",
    "test:commit": "tsx --conditions=react-server lib/github/commit.test.ts",
    "test:portfolios": "tsx lib/github/portfolios.test.ts",
    "test:store": "tsx --conditions=react-server lib/data/github-store.test.ts",
    "test:card-store": "tsx --conditions=react-server lib/data/github-card-store.test.ts",
    "test:validation": "tsx --conditions=react-server lib/data/validation.test.ts",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@octokit/app": "^16.1.2",
    "@opennextjs/cloudflare": "^1.20.1",
    "clsx": "^2.1.1",
    "iron-session": "^8.0.4",
    "js-yaml": "^4.3.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "wrangler": "^4.112.0"
  }
}
